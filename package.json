{
  "name": "zeno-ui",
  "version": "0.1.0",
  "description": "A futuristic, keyboard/mouse-driven Linux desktop environment inspired by eDEX-UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "test": "jest"
  },
  "keywords": [
    "linux",
    "desktop",
    "electron",
    "hacker",
    "terminal"
  ],
  "author": "Zeno-UI Contributors",
  "license": "MIT",
  "dependencies": {
    "node-pty": "^1.0.0",
    "systeminformation": "^5.21.0",
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "build": {
    "appId": "com.zenoui.app",
    "productName": "Zeno-UI",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!node_modules/**/*"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
